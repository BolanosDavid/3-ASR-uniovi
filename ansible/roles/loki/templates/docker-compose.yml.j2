services:
  loki:
    image: grafana/loki:latest
    container_name: loki
    restart: unless-stopped
    command: -config.file=/etc/loki/local-config.yaml
    volumes:
      - ./config/loki-config.yml:/etc/loki/local-config.yaml:ro
      - ./data:/loki
    ports:
      - "{{ wg_overlay_ip }}:3100:3100"