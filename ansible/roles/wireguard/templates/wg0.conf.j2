[Interface]
Address = {{ wg_overlay_ip }}/24
ListenPort = {{ wireguard_port }}
PrivateKey = {{ wireguard_private_key }}

{% for peer in groups['webservers'] | sort if peer != inventory_hostname %}
    [Peer]
    PublicKey = {{ hostvars[peer].wireguard_public_key }}
    Endpoint = {{ hostvars[peer].ansible_host }}:{{ wireguard_port }}
    AllowedIPs = {{ hostvars[peer]['wg_overlay_ip'] }}/32
    PersistentKeepalive = 25

{% endfor %}